@model List<SlojPodataka.EntityModels.UslugaEntityModel>
@{
    ViewData["Title"] = "Usluge";
}
<h2>Šifarnik usluga digitalnog marketinga</h2>

@if (TempData["Greska"] != null)
{
    <div class="alert alert-danger">@TempData["Greska"]</div>
}

<p><a asp-action="Dodaj" class="btn btn-primary">Nova usluga</a></p>

<table class="table table-striped table-bordered">
    <thead class="table-dark"><tr><th>Šifra</th><th>Naziv</th><th>Opis</th><th>Akcije</th></tr></thead>
    <tbody>
    @foreach (var u in Model)
    {
        <tr>
            <td>@u.Sifra</td><td>@u.Naziv</td><td>@u.Opis</td>
            <td>
                <a asp-action="Izmeni" asp-route-id="@u.Sifra" class="btn btn-sm btn-warning">Izmeni</a>
                <form asp-action="Obrisi" asp-route-id="@u.Sifra" method="post" class="d-inline"
                      onsubmit="return confirm('Obrisati ovu uslugu?');">
                    <button type="submit" class="btn btn-sm btn-danger">Briši</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>
