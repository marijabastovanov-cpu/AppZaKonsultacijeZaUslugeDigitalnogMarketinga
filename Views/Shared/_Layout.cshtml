<!DOCTYPE html>
<html lang="sr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MB Studio</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
    <div class="container">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">MB Studio</a>
        <div class="navbar-nav me-auto">
            <a class="nav-link" asp-controller="Zakazivanje" asp-action="Index">Zakaži konsultaciju</a>
            <a class="nav-link" asp-controller="Konsultacije" asp-action="Index">Konsultacije</a>
            <a class="nav-link" asp-controller="Usluge" asp-action="Index">Usluge</a>
        </div>
        <div class="navbar-nav">
            @if (User.Identity != null && User.Identity.IsAuthenticated)
            {
                <span class="navbar-text text-light me-3">@User.FindFirst("ImePrezime")?.Value (@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value)</span>
                <a class="nav-link" asp-controller="Nalog" asp-action="Odjava">Odjava</a>
            }
            else
            {
                <a class="nav-link" asp-controller="Nalog" asp-action="Login">Prijava</a>
            }
        </div>
    </div>
</nav>
<div class="container">
    @RenderBody()
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
